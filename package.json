{
  "name": "fixdesk",
  "version": "0.2.10",
  "private": true,
  "description": "Desktop management system for computer repairs, sales, purchases, inventory, and warranties.",
  "author": {
    "name": "Alfred Fonher",
    "email": "alfredfonher@gmail.com"
  },
  "main": "electron/main.mjs",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && node scripts/copy-next-standalone-assets.mjs",
    "start": "NODE_ENV=production node .next/standalone/server.js 2>&1 | tee server.log",
    "desktop:dev": "ELECTRON_START_URL=http://127.0.0.1:3000 electron .",
    "desktop:dev:linux": "ELECTRON_START_URL=http://127.0.0.1:3000 electron . --no-sandbox",
    "desktop:prod": "ELECTRON_FORCE_PROD_BOOT=1 NODE_ENV=production electron .",
    "desktop:preflight": "node scripts/desktop-preflight.mjs",
    "desktop:preflight:linux": "node scripts/desktop-preflight.mjs --target linux",
    "desktop:preflight:win": "node scripts/desktop-preflight.mjs --target win",
    "desktop:preflight:all": "node scripts/desktop-preflight.mjs --target all",
    "desktop:package": "pnpm run desktop:preflight:win && pnpm run db:generate && pnpm run db:push && pnpm run build && pnpm run db:prepare-packaged && node scripts/cleanup-cam-artifacts.mjs base win && pnpm exec electron-builder --win portable --x64 --publish never",
    "desktop:package:linux": "pnpm run desktop:preflight:linux && pnpm run db:generate && pnpm run db:push && pnpm run build && pnpm run db:prepare-packaged && node scripts/cleanup-cam-artifacts.mjs base linux && USE_SYSTEM_FPM=true CUSTOM_FPM_PATH=/usr/local/bin/fpm pnpm exec electron-builder --linux deb --x64 --publish never",
    "desktop:package:win": "pnpm run desktop:preflight:win && pnpm run db:generate && pnpm run db:push && pnpm run build && pnpm run db:prepare-packaged && node scripts/cleanup-cam-artifacts.mjs base win && pnpm exec electron-builder --win portable --x64 --publish never",
    "desktop:package:all": "pnpm run desktop:package:linux && pnpm run desktop:package:win",
    "desktop:package:linux:cam": "pnpm run desktop:preflight:linux && pnpm run db:generate && pnpm run db:push && pnpm run build && pnpm run db:prepare-packaged && node scripts/cleanup-cam-artifacts.mjs cam linux && USE_SYSTEM_FPM=true CUSTOM_FPM_PATH=/usr/local/bin/fpm pnpm exec electron-builder --config electron-builder.cam.json --linux deb --x64 --publish never",
    "desktop:package:linux:cam:run": "pnpm run desktop:package:linux:cam && node scripts/run-latest-cam-unpacked.mjs",
    "desktop:package:win:cam": "pnpm run desktop:preflight:win && pnpm run db:generate && pnpm run db:push && pnpm run build && pnpm run db:prepare-packaged && node scripts/cleanup-cam-artifacts.mjs cam win && pnpm exec electron-builder --config electron-builder.cam.json --win portable --x64 --publish never",
    "desktop:package:all:cam": "pnpm run desktop:package:linux:cam && pnpm run desktop:package:win:cam",
    "version:bump": "node scripts/bump-version.mjs",
    "lint": "eslint .",
    "test": "pnpm run db:prepare-test && pnpm run db:verify-test && node --test tests/*.test.mjs",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:prepare-packaged": "node scripts/prepare-packaged-db.mjs",
    "db:prepare-test": "node scripts/prepare-test-db.mjs",
    "db:verify-test": "node scripts/verify-test-db.mjs",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@mdxeditor/editor": "^3.39.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@reactuses/core": "^6.0.5",
    "@tanstack/react-query": "^5.82.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.11",
    "next-intl": "^4.3.4",
    "next-themes": "^0.4.6",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^2.15.4",
    "sharp": "^0.34.3",
    "sonner": "^2.0.6",
    "sweetalert2": "^11.26.25",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "z-ai-web-dev-sdk": "^0.0.18",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "25.9.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.fixdesk.desktop",
    "productName": "FixDesk",
    "asar": true,
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": ".next/standalone"
      },
      {
        "from": ".next/static",
        "to": ".next/static"
      },
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "db/custom.db",
        "to": "db/custom.db"
      }
    ],
    "afterPack": "scripts/electron-builder-afterpack.mjs",
    "win": {
      "icon": "public/logo-app.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "artifactName": "FixDesk_Setup_${version}_${arch}.${ext}",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office"
    },
    "deb": {
      "packageName": "fixdesk"
    },
    "directories": {
      "output": "dist-electron"
    }
  }
}
